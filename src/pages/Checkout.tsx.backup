import { useState, useCallback } from "react";
import { useCart } from "@/contexts/CartContext";
import { useNavigate } from "react-router-dom";
import { motion } from "framer-motion";
import { ArrowLeft, Truck, CreditCard, MessageCircle, Loader2 } from "lucide-react";
import { z } from "zod";
import { supabase } from "@/integrations/supabase/client";

const checkoutSchema = z.object({
  name: z.string().trim().min(2, "Nome é obrigatório").max(100),
  whatsapp: z.string().trim().min(10, "WhatsApp inválido").max(20),
  email: z.string().trim().email("E-mail inválido").max(255),
  street: z.string().trim().min(3, "Endereço é obrigatório").max(200),
  number: z.string().trim().min(1, "Número é obrigatório").max(20),
  complement: z.string().max(100).optional(),
  neighborhood: z.string().trim().min(2, "Bairro é obrigatório").max(100),
  city: z.string().trim().min(2, "Cidade é obrigatória").max(100),
  state: z.string().trim().min(2, "Estado é obrigatório").max(2),
  cep: z.string().trim().min(8, "CEP inválido").max(10),
  observations: z.string().max(500).optional(),
});

type PaymentMethod = "pix" | "cartao";

interface ShippingOption {
  id: number;
  name: string;
  company: string;
  price: number;
  delivery_time: number;
  currency: string;
}

const CheckoutPage = () => {
  const { items, subtotal, clearCart } = useCart();
  const navigate = useNavigate();

  const [form, setForm] = useState({
    name: "", whatsapp: "", email: "",
    street: "", number: "", complement: "", neighborhood: "", city: "", state: "", cep: "",
    observations: "",
  });
  const [payment, setPayment] = useState<PaymentMethod>("pix");
  const [errors, setErrors] = useState<Record<string, string>>({});

  // Shipping state
  const [shippingOptions, setShippingOptions] = useState<ShippingOption[]>([]);
  const [selectedShipping, setSelectedShipping] = useState<ShippingOption | null>(null);
  const [shippingLoading, setShippingLoading] = useState(false);
  const [shippingError, setShippingError] = useState("");
  const [lastCepCalculated, setLastCepCalculated] = useState("");

  const shippingPrice = selectedShipping?.price ?? 0;
  const total = subtotal + shippingPrice;

  const updateField = (field: string, value: string) => {
    setForm((f) => ({ ...f, [field]: value }));
    setErrors((e) => ({ ...e, [field]: "" }));
  };

  const calculateShipping = useCallback(async (cep: string) => {
    const cleanCep = cep.replace(/\D/g, "");
    if (cleanCep.length < 8) return;
    if (cleanCep === lastCepCalculated) return;

    setShippingLoading(true);
    setShippingError("");
    setShippingOptions([]);
    setSelectedShipping(null);

    try {
      const products = items.map((i) => ({
        id: i.product.id,
        width: 15,
        height: 15,
        length: 15,
        weight: 0.5,
        insurance_value: i.product.price,
        quantity: i.quantity,
      }));

      const { data, error } = await supabase.functions.invoke("calculate-shipping", {
        body: { postal_code: cleanCep, products },
      });

      if (error) throw new Error(error.message);

      if (data?.options?.length) {
        setShippingOptions(data.options);
        setSelectedShipping(data.options[0]);
        setLastCepCalculated(cleanCep);
      } else {
        setShippingError("Nenhuma opção de frete disponível para este CEP.");
      }
    } catch (err: any) {
      console.error("Shipping calc error:", err);
      setShippingError("Erro ao calcular frete. Verifique o CEP e tente novamente.");
    } finally {
      setShippingLoading(false);
    }
  }, [items, lastCepCalculated]);

  const handleSubmit = () => {
    const result = checkoutSchema.safeParse(form);
    if (!result.success) {
      const fieldErrors: Record<string, string> = {};
      result.error.errors.forEach((e) => {
        if (e.path[0]) fieldErrors[e.path[0] as string] = e.message;
      });
      setErrors(fieldErrors);
      return;
    }

    if (!selectedShipping) {
      setShippingError("Selecione uma opção de frete. Digite o CEP para calcular.");
      return;
    }

    const message = encodeURIComponent(
      `*Novo Pedido - Laura Veríssimo Ateliê*\n` +
      `---\n` +
      `*Cliente:* ${form.name}\n` +
      `*WhatsApp:* ${form.whatsapp}\n` +
      `*E-mail:* ${form.email}\n` +
      `*Itens:*\n${items.map((i) => `- ${i.quantity}x ${i.product.name} (R$ ${(i.product.price * i.quantity).toFixed(2).replace(".", ",")})`).join("\n")}\n` +
      (form.observations ? `*Observações da Arte:* ${form.observations}\n` : "") +
      `---\n` +
      `*Entrega:* ${selectedShipping.company} - ${selectedShipping.name} (R$ ${shippingPrice.toFixed(2).replace(".", ",")}) - ${selectedShipping.delivery_time} dias úteis\n` +
      `*Pagamento:* ${payment === "pix" ? "PIX" : "Cartão de Crédito (Link)"}\n` +
      `*Total:* R$ ${total.toFixed(2).replace(".", ",")}\n` +
      `---\n` +
      `*Endereço:* ${form.street}, ${form.number}${form.complement ? ` - ${form.complement}` : ""}, ${form.neighborhood}, ${form.city}/${form.state} - CEP: ${form.cep}`
    );

    window.open(`https://wa.me/5575991610314?text=${message}`, "_blank");
    clearCart();
    navigate("/");
  };

  if (items.length === 0) {
    return (
      <div className="min-h-screen flex items-center justify-center pt-20">
        <div className="text-center">
          <h2 className="text-display text-3xl text-foreground mb-4">Carrinho vazio</h2>
          <button onClick={() => navigate("/")} className="btn-primary">
            Voltar à Galeria
          </button>
        </div>
      </div>
    );
  }

  const inputClass = (field: string) =>
    `w-full px-4 py-3 rounded-full bg-secondary/50 border font-sans text-sm text-foreground placeholder:text-muted-foreground/60 focus:outline-none focus:ring-2 focus:ring-accent transition-all duration-300 ${
      errors[field] ? "border-destructive" : "border-border/50"
    }`;

  const sectionAnim = (delay: number) => ({
    initial: { opacity: 0, y: 15 } as const,
    animate: { opacity: 1, y: 0 } as const,
    transition: { delay, duration: 0.6, ease: [0.22, 1, 0.36, 1] as [number, number, number, number] },
  });

  return (
    <div className="min-h-screen pt-24 pb-16">
      <div className="container mx-auto px-6 max-w-3xl">
        <motion.button
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
          onClick={() => navigate("/")}
          className="flex items-center gap-2 font-sans text-sm text-muted-foreground hover:text-foreground transition-colors mb-8"
        >
          <ArrowLeft className="h-4 w-4" />
          Voltar à Galeria
        </motion.button>

        <motion.h1
          initial={{ opacity: 0, y: 15 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.6, ease: [0.22, 1, 0.36, 1] }}
          className="text-display text-4xl md:text-5xl text-foreground mb-10"
        >
          Finalizar <span className="italic gold-accent">Pedido</span>
        </motion.h1>

        <div className="space-y-10">
          {/* Identification */}
          <motion.section {...sectionAnim(0.1)} className="glass-card p-6 md:p-8">
            <h2 className="text-display text-2xl text-foreground mb-6">Identificação</h2>
            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <input type="text" placeholder="Nome completo" value={form.name}
                  onChange={(e) => updateField("name", e.target.value)}
                  className={inputClass("name")} maxLength={100} />
                {errors.name && <p className="text-destructive text-xs mt-1 ml-4 font-sans">{errors.name}</p>}
              </div>
              <div>
                <input type="tel" placeholder="WhatsApp (com DDD)" value={form.whatsapp}
                  onChange={(e) => updateField("whatsapp", e.target.value)}
                  className={inputClass("whatsapp")} maxLength={20} />
                {errors.whatsapp && <p className="text-destructive text-xs mt-1 ml-4 font-sans">{errors.whatsapp}</p>}
              </div>
              <div className="md:col-span-2">
                <input type="email" placeholder="E-mail" value={form.email}
                  onChange={(e) => updateField("email", e.target.value)}
                  className={inputClass("email")} maxLength={255} />
                {errors.email && <p className="text-destructive text-xs mt-1 ml-4 font-sans">{errors.email}</p>}
              </div>
            </div>
          </motion.section>

          {/* Address */}
          <motion.section {...sectionAnim(0.2)} className="glass-card p-6 md:p-8">
            <h2 className="text-display text-2xl text-foreground mb-6">Endereço de Entrega</h2>
            <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div className="md:col-span-2">
                <input placeholder="Rua / Avenida" value={form.street}
                  onChange={(e) => updateField("street", e.target.value)}
                  className={inputClass("street")} maxLength={200} />
                {errors.street && <p className="text-destructive text-xs mt-1 ml-4 font-sans">{errors.street}</p>}
              </div>
              <div>
                <input placeholder="Número" value={form.number}
                  onChange={(e) => updateField("number", e.target.value)}
                  className={inputClass("number")} maxLength={20} />
                {errors.number && <p className="text-destructive text-xs mt-1 ml-4 font-sans">{errors.number}</p>}
              </div>
              <div>
                <input placeholder="Complemento" value={form.complement}
                  onChange={(e) => updateField("complement", e.target.value)}
                  className={inputClass("complement")} maxLength={100} />
              </div>
              <div>
                <input placeholder="Bairro" value={form.neighborhood}
                  onChange={(e) => updateField("neighborhood", e.target.value)}
                  className={inputClass("neighborhood")} maxLength={100} />
                {errors.neighborhood && <p className="text-destructive text-xs mt-1 ml-4 font-sans">{errors.neighborhood}</p>}
              </div>
              <div>
                <div className="flex gap-2">
                  <input placeholder="CEP" value={form.cep}
                    onChange={(e) => updateField("cep", e.target.value)}
                    onBlur={() => calculateShipping(form.cep)}
                    className={inputClass("cep")} maxLength={10} />
                  <button
                    type="button"
                    onClick={() => calculateShipping(form.cep)}
                    disabled={shippingLoading || form.cep.replace(/\D/g, "").length < 8}
                    className="px-4 py-3 rounded-full bg-accent text-accent-foreground font-sans text-xs uppercase tracking-widest hover:bg-accent/80 transition-colors disabled:opacity-50 whitespace-nowrap"
                  >
                    {shippingLoading ? <Loader2 className="h-4 w-4 animate-spin" /> : "Calcular"}
                  </button>
                </div>
                {errors.cep && <p className="text-destructive text-xs mt-1 ml-4 font-sans">{errors.cep}</p>}
              </div>
              <div>
                <input placeholder="Cidade" value={form.city}
                  onChange={(e) => updateField("city", e.target.value)}
                  className={inputClass("city")} maxLength={100} />
                {errors.city && <p className="text-destructive text-xs mt-1 ml-4 font-sans">{errors.city}</p>}
              </div>
              <div>
                <input placeholder="UF" value={form.state}
                  onChange={(e) => updateField("state", e.target.value.toUpperCase())}
                  className={inputClass("state")} maxLength={2} />
                {errors.state && <p className="text-destructive text-xs mt-1 ml-4 font-sans">{errors.state}</p>}
              </div>
            </div>
          </motion.section>

          {/* Shipping */}
          <motion.section {...sectionAnim(0.3)} className="glass-card p-6 md:p-8">
            <h2 className="text-display text-2xl text-foreground mb-6 flex items-center gap-3">
              <Truck className="h-5 w-5 gold-accent" />
              Entrega
            </h2>

            {shippingLoading && (
              <div className="flex items-center justify-center gap-3 py-8">
                <Loader2 className="h-5 w-5 animate-spin text-accent" />
                <span className="font-sans text-sm text-muted-foreground">Calculando frete...</span>
              </div>
            )}

            {shippingError && (
              <p className="font-sans text-sm text-destructive text-center py-4">{shippingError}</p>
            )}

            {!shippingLoading && shippingOptions.length === 0 && !shippingError && (
              <p className="font-sans text-sm text-muted-foreground text-center py-4">
                Digite o CEP acima e clique em "Calcular" para ver as opções de frete.
              </p>
            )}

            {shippingOptions.length > 0 && (
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                {shippingOptions.map((opt) => (
                  <button
                    key={opt.id}
                    onClick={() => setSelectedShipping(opt)}
                    className={`p-5 rounded-atelier border-2 text-left transition-all duration-300 ${
                      selectedShipping?.id === opt.id
                        ? "border-accent bg-accent/5"
                        : "border-border/30 bg-secondary/30 hover:border-border"
                    }`}
                  >
                    <span className="font-sans text-sm font-medium text-foreground block">
                      {opt.company} — {opt.name}
                    </span>
                    <span className="font-sans text-xs text-muted-foreground">
                      R$ {opt.price.toFixed(2).replace(".", ",")} · {opt.delivery_time} dias úteis
                    </span>
                  </button>
                ))}
              </div>
            )}
          </motion.section>

          {/* Payment */}
          <motion.section {...sectionAnim(0.4)} className="glass-card p-6 md:p-8">
            <h2 className="text-display text-2xl text-foreground mb-6 flex items-center gap-3">
              <CreditCard className="h-5 w-5 gold-accent" />
              Pagamento
            </h2>
            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
              <button
                onClick={() => setPayment("pix")}
                className={`p-5 rounded-atelier border-2 text-left transition-all duration-300 ${
                  payment === "pix"
                    ? "border-accent bg-accent/5"
                    : "border-border/30 bg-secondary/30 hover:border-border"
                }`}
              >
                <span className="font-sans text-sm font-medium text-foreground block">PIX</span>
                <span className="font-sans text-xs text-muted-foreground">Aprovação imediata</span>
              </button>
              <button
                onClick={() => setPayment("cartao")}
                className={`p-5 rounded-atelier border-2 text-left transition-all duration-300 ${
                  payment === "cartao"
                    ? "border-accent bg-accent/5"
                    : "border-border/30 bg-secondary/30 hover:border-border"
                }`}
              >
                <span className="font-sans text-sm font-medium text-foreground block">Cartão de Crédito</span>
                <span className="font-sans text-xs text-muted-foreground">Via link de pagamento</span>
              </button>
            </div>
          </motion.section>

          {/* Art notes */}
          <motion.section {...sectionAnim(0.5)} className="glass-card p-6 md:p-8">
            <h2 className="text-display text-2xl text-foreground mb-2">Observações da Arte</h2>
            <p className="font-sans text-sm text-muted-foreground mb-4">
              Descreva detalhes sobre personalização, cores ou iniciais desejadas.
            </p>
            <textarea
              value={form.observations}
              onChange={(e) => updateField("observations", e.target.value)}
              placeholder="Ex: Gostaria de iniciais em dourado na base da taça..."
              rows={3}
              maxLength={500}
              className="w-full px-5 py-4 rounded-atelier bg-secondary/50 border border-border/50 font-sans text-sm text-foreground placeholder:text-muted-foreground/60 focus:outline-none focus:ring-2 focus:ring-accent transition-all duration-300 resize-none"
            />
          </motion.section>

          {/* Summary */}
          <motion.section {...sectionAnim(0.6)} className="glass-card p-6 md:p-8">
            <h2 className="text-display text-2xl text-foreground mb-6">Resumo</h2>
            <div className="space-y-3 mb-6">
              {items.map((item) => (
                <div key={item.product.id} className="flex justify-between font-sans text-sm">
                  <span className="text-foreground">
                    {item.quantity}x {item.product.name}
                  </span>
                  <span className="text-foreground tabular-nums">
                    R$ {(item.product.price * item.quantity).toFixed(2).replace(".", ",")}
                  </span>
                </div>
              ))}
              <div className="border-t border-border/30 pt-3 flex justify-between font-sans text-sm">
                <span className="text-muted-foreground">
                  Frete {selectedShipping ? `(${selectedShipping.company})` : ""}
                </span>
                <span className="text-foreground tabular-nums">
                  {selectedShipping
                    ? `R$ ${shippingPrice.toFixed(2).replace(".", ",")}`
                    : "—"}
                </span>
              </div>
            </div>
            <div className="flex justify-between items-center border-t border-border/30 pt-4">
              <span className="font-sans text-sm uppercase tracking-[0.15em] text-muted-foreground">
                Total
              </span>
              <span className="text-display text-3xl text-foreground tabular-nums">
                R$ {total.toFixed(2).replace(".", ",")}
              </span>
            </div>
            <button
              onClick={handleSubmit}
              disabled={!selectedShipping}
              className="btn-gold w-full text-center mt-6 flex items-center justify-center gap-3 disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <MessageCircle className="h-4 w-4" />
              Finalizar via WhatsApp
            </button>
          </motion.section>
        </div>
      </div>
    </div>
  );
};

export default CheckoutPage;
