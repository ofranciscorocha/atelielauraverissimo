// LAURA VERISSIMO ATELIER - DATABASE SCHEMA
// Persona-Centric CRM + E-commerce Artesanal Premium

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// CRM B2C - CLIENTES PERSONA-CENTRIC
// ========================================

model Client {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Dados Pessoais
  name      String
  email     String   @unique
  phone     String
  cpf       String?  @unique

  // Endereço
  address   String?
  city      String?
  state     String?
  zipCode   String?

  // CRM Analytics
  ranking         ClientRanking @default(NOVO)
  lifetimeValue   Decimal       @default(0) @db.Decimal(10, 2)
  totalOrders     Int           @default(0)
  averageTicket   Decimal       @default(0) @db.Decimal(10, 2)
  lastPurchaseAt  DateTime?

  // Segmentação Comportamental
  segment         ClientSegment @default(POTENCIAL)
  notes           String?       @db.Text
  tags            String[]      @default([])

  // Perfil de Estilo (Persona Artística)
  styleVibe       String?       @db.Text // "Vibração de Estilo" do cliente

  // Marketing
  emailOptIn      Boolean       @default(true)
  whatsappOptIn   Boolean       @default(true)

  // Relacionamentos
  orders          Order[]
  marketingLogs   MarketingLog[]

  @@index([ranking])
  @@index([segment])
  @@index([email])
}

enum ClientRanking {
  NOVO          // Primeira compra
  BRONZE        // 2-3 compras
  PRATA         // 4-6 compras
  OURO          // 7-10 compras
  PLATINA       // 11+ compras
  VIP           // Clientes especiais/corporativos
}

enum ClientSegment {
  POTENCIAL     // Novo cliente sem compra
  RECORRENTE    // Comprou nos últimos 3 meses
  EM_RISCO      // Não compra há 4-6 meses
  INATIVO       // Não compra há mais de 6 meses
  CHAMPION      // Alto valor + alta frequência
}

// ========================================
// PRODUTOS & VARIANTES
// ========================================

model Product {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Informações Básicas
  name        String
  description String   @db.Text
  category    String

  // Precificação
  basePrice   Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)

  // SEO & Marketing
  slug        String   @unique
  tags        String[] @default([])

  // Relacionamentos
  variants    ProductVariant[]
  orderItems  OrderItem[]

  @@index([slug])
  @@index([isActive])
}

model ProductVariant {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Características da Variante
  model       String   // Ex: "Taça Gin", "Taça Vinho"
  color       String   // Ex: "Verde Esmeralda", "Dourado"
  capacity    String   // Ex: "650ml", "400ml"

  // Imagens Específicas da Variante
  imageUrls   String[] @default([])

  // Estoque & Preço
  stockQty    Int      @default(0)
  priceAdjust Decimal  @default(0) @db.Decimal(10, 2) // Ajuste sobre o basePrice
  sku         String   @unique

  // Relacionamentos
  orderItems  OrderItem[]

  @@index([productId])
  @@index([sku])
}

// ========================================
// PEDIDOS & PRODUÇÃO
// ========================================

model Order {
  id          String      @id @default(cuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Cliente
  clientId    String
  client      Client      @relation(fields: [clientId], references: [id])

  // Status do Pedido
  status      OrderStatus @default(AGUARDANDO_PAGAMENTO)

  // Produção (Fluxo Granular)
  productionStatus ProductionStatus @default(NAO_INICIADO)

  // Valores
  subtotal    Decimal     @db.Decimal(10, 2)
  shippingFee Decimal     @db.Decimal(10, 2)
  total       Decimal     @db.Decimal(10, 2)

  // Entrega
  estimatedProductionDays Int
  estimatedDeliveryDate   DateTime?
  shippingTrackingCode    String?

  // Mensagem Especial do Cliente
  specialMessage String?   @db.Text // "Recadinho Especial"

  // Observações Internas
  internalNotes String?    @db.Text

  // Relacionamentos
  items       OrderItem[]
  finance     FinanceEntry?

  @@index([clientId])
  @@index([status])
  @@index([productionStatus])
}

enum OrderStatus {
  AGUARDANDO_PAGAMENTO
  PAGO
  EM_PRODUCAO
  PRONTO_PARA_ENVIO
  ENVIADO
  ENTREGUE
  CANCELADO
}

enum ProductionStatus {
  NAO_INICIADO
  PREPARO          // Separação de materiais
  PINTURA          // Processo de pintura
  CURA             // Secagem/cura da tinta
  INSPECAO         // Controle de qualidade
  ACABAMENTO       // Detalhes finais
  EMBALAGEM        // Processo de embalagem
  CONCLUIDO        // Pronto para envio
}

model OrderItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product  @relation(fields: [productId], references: [id])

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  subtotal  Decimal  @db.Decimal(10, 2)

  @@index([orderId])
}

// ========================================
// ESTOQUE & INSUMOS
// ========================================

model Supplier {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Informações Básicas
  name        String
  contactName String?
  email       String?
  phone       String
  whatsappUrl String?  // Link direto para WhatsApp

  // Avaliação
  qualityRating Int @default(3) // 1-5 estrelas
  leadTimeDays  Int @default(7) // Prazo médio de entrega

  // Relacionamentos
  supplies    Supply[]
  stockMovements StockMovement[]

  @@index([qualityRating])
}

model Supply {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Identificação
  name        String
  category    SupplyCategory
  sku         String   @unique

  // Fornecedor
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])

  // Estoque
  currentStock    Int      @default(0)
  minStockLevel   Int      @default(10) // Gatilho de "Estoque Baixo"
  unit            String   // Ex: "ml", "unidade", "kg"

  // Custo
  unitCost        Decimal  @db.Decimal(10, 2)

  // Alertas
  isLowStock      Boolean  @default(false) // Calculado automaticamente

  // Relacionamentos
  stockMovements  StockMovement[]

  @@index([category])
  @@index([isLowStock])
}

enum SupplyCategory {
  CRISTAL         // Taças, copos
  TINTA           // Tintas para vidro
  PINCEL          // Pincéis e ferramentas
  EMBALAGEM       // Caixas, papel, fitas
  ACESSORIO       // Fitas, etiquetas, etc
  OUTRO           // Outros insumos
}

model StockMovement {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  // Insumo
  supplyId    String
  supply      Supply   @relation(fields: [supplyId], references: [id])

  // Tipo de Movimentação
  type        MovementType
  quantity    Int

  // Relacionamentos
  orderId     String?      // Vinculado a um pedido (produção)
  supplierId  String?      // Vinculado a uma compra de fornecedor
  supplier    Supplier?    @relation(fields: [supplierId], references: [id])

  // Observações
  notes       String?      @db.Text

  @@index([supplyId])
  @@index([createdAt])
  @@index([type])
}

enum MovementType {
  ENTRADA         // Compra de insumos
  SAIDA_PRODUCAO  // Uso em produção
  AJUSTE          // Ajuste de inventário
  PERDA           // Perda/dano
}

// ========================================
// FINANCEIRO
// ========================================

model FinanceEntry {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Tipo de Transação
  type        FinanceType
  category    String        // Ex: "Vendas", "Materiais", "Marketing"

  // Valores
  amount      Decimal       @db.Decimal(10, 2)
  description String

  // Relacionamento com Pedido (se aplicável)
  orderId     String?       @unique
  order       Order?        @relation(fields: [orderId], references: [id])

  // Análise de Margem
  costOfGoods Decimal?      @db.Decimal(10, 2) // Custo dos materiais
  profit      Decimal?      @db.Decimal(10, 2) // Lucro líquido

  @@index([type])
  @@index([createdAt])
}

enum FinanceType {
  RECEITA   // Entrada (vendas)
  DESPESA   // Saída (materiais, marketing, etc)
}

// ========================================
// MARKETING & IA
// ========================================

model MarketingLog {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())

  // Cliente Alvo
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id])

  // Canal
  channel     MarketingChannel

  // Conteúdo
  subject     String?
  content     String        @db.Text

  // Status
  status      MessageStatus @default(ENVIADO)

  // Métricas
  openedAt    DateTime?
  clickedAt   DateTime?

  @@index([clientId])
  @@index([channel])
  @@index([createdAt])
}

enum MarketingChannel {
  EMAIL
  WHATSAPP
  SMS
}

enum MessageStatus {
  ENVIADO
  ENTREGUE
  ABERTO
  CLICADO
  ERRO
}

model AIGeneratedArt {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  // Prompt Original do Cliente
  originalPrompt String @db.Text

  // Prompt Refinado pela IA (Nano Banana Pro)
  refinedPrompt  String @db.Text

  // Imagem Gerada
  imageUrl       String
  imageUrlNoWatermark String? // URL da imagem final sem marca d'água

  // Metadata
  style          String  // Ex: "Aquarela", "Abstrato"
  colors         String[]

  // Status
  approved       Boolean @default(false)
  usedInProduct  Boolean @default(false)

  @@index([createdAt])
}

// ========================================
// AGENDA & PRODUÇÃO
// ========================================

model ProductionEvent {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Evento
  title       String
  description String?  @db.Text
  date        DateTime

  // Tipo de Evento
  eventType   EventType

  // Relacionamento com Pedido
  orderId     String?

  // Status
  completed   Boolean  @default(false)

  @@index([date])
  @@index([eventType])
}

enum EventType {
  PRODUCAO      // Dia de produção agendado
  ENTREGA       // Prazo de entrega
  FEIRA         // Evento externo
  OUTRO         // Eventos diversos
}

// ========================================
// CONFIGURAÇÕES DO SISTEMA
// ========================================

model Settings {
  id        String   @id @default(cuid())
  updatedAt DateTime @updatedAt

  // Branding
  logoUrl         String?
  primaryColor    String @default("#304930")
  secondaryColor  String @default("#F0F4F0")
  accentColor     String @default("#D4AF37")

  // Banners (JSON)
  bannersJson     String @default("[]") @db.Text

  // Regras de Produção
  minProductionDays Int @default(7)
  maxProductionDays Int @default(15)

  // Frete
  shippingInfo      String @default("Frete fixo para todo o Brasil. Consulte condições.")

  // WhatsApp
  whatsappNumber    String @default("5511999999999")
  whatsappMessage   String @default("Olá! Gostaria de finalizar meu pedido 💚") @db.Text

  // OpenAI (Nano Banana Pro)
  openaiApiKey      String?
}
